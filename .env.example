# ────────────────────────────────────────────────────────────
#   Joblit — Environment Variable Template
#
#   Copy this file to `.env` and fill in real values.
#   Anything marked REQUIRED must be set for the app to boot.
#   Anything marked OPTIONAL only enables that feature.
#
#   NEVER commit `.env` to version control.
# ────────────────────────────────────────────────────────────

# ── Database ────────────────────────────────────────────────
# REQUIRED. Postgres connection string. Neon serverless format:
#   postgres://user:pass@ep-xxxx.neon.tech/dbname?sslmode=require
DATABASE_URL=

# ── Auth ────────────────────────────────────────────────────
# REQUIRED. Generate via: openssl rand -base64 32
AUTH_SECRET=

# REQUIRED. Google OAuth credentials.
# Create at: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# REQUIRED. GitHub OAuth credentials.
# Create at: https://github.com/settings/developers
GITHUB_ID=
GITHUB_SECRET=

# ── Internal API Auth ───────────────────────────────────────
# REQUIRED. Shared secret used by the JobSpy fetch worker when
# calling /api/admin/import. Generate via: openssl rand -hex 32
IMPORT_SECRET=

# REQUIRED. Shared secret used by the fetch worker when fetching
# its run configuration from /api/fetch-runs/[id]/config.
FETCH_RUN_SECRET=

# REQUIRED. Base64-encoded encryption key for the extension token
# storage. Generate via: openssl rand -base64 32
APP_ENC_KEY=

# ── LaTeX PDF Render Service ────────────────────────────────
# REQUIRED. External service that compiles .tex -> .pdf.
LATEX_RENDER_URL=
LATEX_RENDER_TOKEN=

# ── AI Provider (optional) ──────────────────────────────────
# OPTIONAL. Without these, AI tailoring falls back to the
# manual JSON import path.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# ── Vercel Blob (optional) ──────────────────────────────────
# OPTIONAL. Without it, generated PDFs are returned inline only.
BLOB_READ_WRITE_TOKEN=

# ── Fetch Worker Dispatch (optional) ────────────────────────
# OPTIONAL. Required only if you trigger the JobSpy fetcher via
# GitHub Actions workflow_dispatch.
GITHUB_OWNER=
GITHUB_REPO=
GITHUB_TOKEN=
GITHUB_WORKFLOW_FILE=jobspy-fetch.yml

# OPTIONAL. Public URL of the deployed app (extension callback).
JOBLIT_WEB_URL=https://www.joblit.tech

# ── Discover (optional) ─────────────────────────────────────
# OPTIONAL. YouTube curated video pipeline.
YOUTUBE_API_KEY=

# ── Cron (optional) ─────────────────────────────────────────
# OPTIONAL. Auth for cron endpoints (Vercel cron / external).
CRON_SECRET=

# ── China Job Sources (optional) ────────────────────────────
# OPTIONAL.
RSSHUB_URL=
RSSHUB_JOB_ROUTES=
GITHUB_CN_JOB_REPOS=

# ── Observability (optional) ────────────────────────────────
# OPTIONAL. When @sentry/nextjs is installed, this DSN routes
# errorReporter output to Sentry.
SENTRY_DSN=
