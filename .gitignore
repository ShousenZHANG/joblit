# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# oh-my-claudecode state
.omc/

# dependencies
node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# superpowers plans (generated)
docs/superpowers/plans/

# superpowers specs and visual companions (local design artifacts)
docs/superpowers/specs/
docs/superpowers/*.html

# agent/skills (npx skills add; local, do not commit)
.agent/
.agents/
.tabnine/
skills-lock.json

# Claude Code local config and worktrees
.claude/

# Everything Claude Code plugin (local tooling)
everything-claude-code/
install.cmd

# Generated reports and codemaps
.reports/
docs/CODEMAPS/
docs/refactor-report.md

# typescript
*.tsbuildinfo
next-env.d.ts

# ensure server code is tracked even with global ignores
!lib/
!lib/server/
!lib/server/**/*.ts

# Design reference docs (getdesign artifacts)
docs/design-references/
DESIGN.md
design-system/
