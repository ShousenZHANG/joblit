{
  "manifest_version": 3,
  "name": "Jobflow AutoFill",
  "version": "0.1.0",
  "description": "Auto-fill job application forms with your Jobflow profile data",
  "default_locale": "en",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": [
    "storage",
    "activeTab",
    "scripting"
  ],
  "optional_host_permissions": [
    "https://*/*"
  ],
  "host_permissions": [
    "https://*.greenhouse.io/*",
    "https://jobs.lever.co/*",
    "https://*.myworkdayjobs.com/*",
    "https://*.icims.com/*",
    "https://*.successfactors.com/*"
  ],
  "background": {
    "service_worker": "src/background/index.ts",
    "type": "module"
  },
  "action": {
    "default_popup": "src/popup/index.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "https://*.greenhouse.io/*",
        "https://jobs.lever.co/*",
        "https://*.myworkdayjobs.com/*",
        "https://*.icims.com/*",
        "https://*.successfactors.com/*"
      ],
      "js": ["src/content/index.ts"],
      "css": [],
      "run_at": "document_idle"
    }
  ],
  "commands": {
    "fill-form": {
      "suggested_key": {
        "default": "Alt+Shift+F"
      },
      "description": "Auto-fill the current form"
    },
    "toggle-widget": {
      "suggested_key": {
        "default": "Alt+Shift+W"
      },
      "description": "Toggle the Jobflow widget"
    }
  }
}
