// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum JobStatus {
  NEW
  APPLIED
  REJECTED
}

enum FetchRunStatus {
  QUEUED
  RUNNING
  SUCCEEDED
  FAILED
  PARTIAL
}

enum OnboardingStage {
  NEW_USER
  ACTIVATED_USER
  RETURNING_USER
}

enum ApplicationBatchScope {
  NEW
}

enum ApplicationBatchStatus {
  QUEUED
  RUNNING
  SUCCEEDED
  FAILED
  CANCELLED
}

enum ApplicationBatchTaskStatus {
  PENDING
  RUNNING
  SUCCEEDED
  FAILED
  SKIPPED
}

model User {
  id            String    @id @default(uuid()) @db.Uuid
  email         String?   @unique
  name          String?
  image         String?
  emailVerified DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts Account[]
  sessions Session[]

  jobs                  Job[]
  fetchRuns             FetchRun[]
  deletedJobUrls        DeletedJobUrl[]
  dailyCheckins         DailyCheckin[]
  resumeProfiles        ResumeProfile[]
  activeResumeProfiles  ActiveResumeProfile[]
  applications          Application[]
  promptRuleTemplates   PromptRuleTemplate[]
  onboardingState       OnboardingState?
  applicationBatches    ApplicationBatch[]
  applicationBatchTasks ApplicationBatchTask[]
  extensionTokens       ExtensionToken[]
  formSubmissions       FormSubmission[]
  fieldMappingRules     FieldMappingRule[]
}

model Account {
  id     String @id @default(uuid()) @db.Uuid
  userId String @db.Uuid
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  type              String
  provider          String
  providerAccountId String

  refresh_token String?
  access_token  String?
  expires_at    Int?
  token_type    String?
  scope         String?
  id_token      String?
  session_state String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(uuid()) @db.Uuid
  sessionToken String   @unique
  userId       String   @db.Uuid
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expires      DateTime

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model Job {
  id     String @id @default(uuid()) @db.Uuid
  userId String @db.Uuid
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  jobUrl      String
  title       String
  company     String?
  location    String?
  jobType     String?
  jobLevel    String?
  description String?
  status      JobStatus @default(NEW)
  market      String    @default("AU") // "AU" | "CN"

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  applications          Application[]
  applicationBatchTasks ApplicationBatchTask[]
  formSubmissions       FormSubmission[]
  // GIN trigram indexes (title, company, location) created via raw SQL migration

  @@unique([userId, jobUrl])
  @@index([userId, createdAt])
  @@index([userId, updatedAt])
  @@index([userId, status])
  @@index([userId, market, createdAt])
  @@index([userId, jobLevel])
}

model ApplicationBatch {
  id     String @id @default(uuid()) @db.Uuid
  userId String @db.Uuid
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  scope       ApplicationBatchScope  @default(NEW)
  status      ApplicationBatchStatus @default(QUEUED)
  totalCount  Int
  error       String?
  startedAt   DateTime?
  completedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tasks ApplicationBatchTask[]

  @@index([userId, createdAt])
  @@index([userId, status, updatedAt])
}

model ApplicationBatchTask {
  id      String           @id @default(uuid()) @db.Uuid
  batchId String           @db.Uuid
  batch   ApplicationBatch @relation(fields: [batchId], references: [id], onDelete: Cascade)
  userId  String           @db.Uuid
  user    User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  jobId   String           @db.Uuid
  job     Job              @relation(fields: [jobId], references: [id], onDelete: Cascade)

  status      ApplicationBatchTaskStatus @default(PENDING)
  error       String?
  startedAt   DateTime?
  completedAt DateTime?
  attempt     Int                        @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([batchId, jobId])
  @@index([batchId, status, createdAt])
  @@index([userId, status, createdAt])
}

model DeletedJobUrl {
  id     String @id @default(uuid()) @db.Uuid
  userId String @db.Uuid
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  jobUrl    String
  deletedAt DateTime @default(now())

  @@unique([userId, jobUrl])
  @@index([userId, deletedAt])
}

model DailyCheckin {
  id     String @id @default(uuid()) @db.Uuid
  userId String @db.Uuid
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  localDate String
  checkedAt DateTime @default(now())

  @@unique([userId, localDate])
  @@index([userId, localDate])
}

model FetchRun {
  id     String @id @default(uuid()) @db.Uuid
  userId String @db.Uuid
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Snapshot for convenience (used by GitHub Actions to import to the correct user)
  userEmail String
  market    String @default("AU") // "AU" | "CN"

  status        FetchRunStatus @default(QUEUED)
  error         String?
  importedCount Int            @default(0)

  // Fetch parameters (JSON so we can evolve without migrations)
  queries            Json
  location           String?
  hoursOld           Int?
  resultsWanted      Int?
  includeFromQueries Boolean @default(false)
  filterDescription  Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, createdAt])
  @@index([userId, status])
}

model ResumeProfile {
  id       String @id @default(uuid()) @db.Uuid
  userId   String @db.Uuid
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  name     String @default("Custom Blank")
  revision Int    @default(1)
  locale   String @default("en-AU") // "en-AU" | "zh-CN"

  summary     String?
  basics      Json?
  links       Json?
  skills      Json?
  experiences Json?
  projects    Json?
  education   Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  applications     Application[]
  activeSelections ActiveResumeProfile[]

  @@index([userId, name])
  @@index([userId, updatedAt])
  @@index([userId, locale, updatedAt])
}

model ActiveResumeProfile {
  userId          String        @db.Uuid
  locale          String        @default("en-AU") // "en-AU" | "zh-CN"
  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  resumeProfileId String        @db.Uuid
  resumeProfile   ResumeProfile @relation(fields: [resumeProfileId], references: [id], onDelete: Cascade)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@id([userId, locale])
  @@index([resumeProfileId])
}

model Application {
  id     String @id @default(uuid()) @db.Uuid
  userId String @db.Uuid
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  jobId String? @db.Uuid
  job   Job?    @relation(fields: [jobId], references: [id], onDelete: SetNull)

  resumeProfileId String?        @db.Uuid
  resumeProfile   ResumeProfile? @relation(fields: [resumeProfileId], references: [id], onDelete: SetNull)

  company String?
  role    String?

  resumeTexUrl  String?
  resumePdfUrl  String?
  resumePdfName String?
  coverTexUrl   String?
  coverPdfUrl   String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, jobId])
  @@index([userId, createdAt])
}

model PromptRuleTemplate {
  id     String @id @default(uuid()) @db.Uuid
  userId String @db.Uuid
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  name            String
  version         Int
  locale          String  @default("en-AU")
  cvRules         Json
  coverRules      Json
  hardConstraints Json
  isActive        Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, version])
  @@index([userId, isActive, updatedAt])
}

model ExtensionToken {
  id     String @id @default(uuid()) @db.Uuid
  userId String @db.Uuid
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  tokenHash  String    @unique // SHA-256 hash of the actual token
  name       String    @default("Chrome Extension")
  lastUsedAt DateTime?
  expiresAt  DateTime
  revokedAt  DateTime?

  createdAt DateTime @default(now())

  @@index([userId, revokedAt])
}

model FormSubmission {
  id     String @id @default(uuid()) @db.Uuid
  userId String @db.Uuid
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  jobId String? @db.Uuid
  job   Job?    @relation(fields: [jobId], references: [id], onDelete: SetNull)

  pageUrl       String
  pageDomain    String
  atsProvider   String?
  formSignature String
  fieldValues   Json
  fieldMappings Json
  submittedAt   DateTime @default(now())

  createdAt DateTime @default(now())

  @@index([userId, pageDomain, formSignature])
  @@index([userId, submittedAt])
  @@index([userId, atsProvider])
}

model FieldMappingRule {
  id     String @id @default(uuid()) @db.Uuid
  userId String @db.Uuid
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  fieldSelector String
  fieldLabel    String?
  atsProvider   String  @default("")
  pageDomain    String  @default("")

  profilePath String
  staticValue String?

  source     String @default("user")
  confidence Float  @default(1.0)
  useCount   Int    @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, fieldSelector, atsProvider, pageDomain])
  @@index([userId, atsProvider, fieldLabel])
  @@index([userId, pageDomain])
}

model OnboardingState {
  id     String @id @default(uuid()) @db.Uuid
  userId String @unique @db.Uuid
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  stage       OnboardingStage @default(NEW_USER)
  checklist   Json?
  dismissedAt DateTime?
  completedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, stage, updatedAt])
}

// Persistent cache for the Discover → Videos pipeline. Replaces the
// previous in-memory Map, which was wiped on every serverless cold
// start and caused the YouTube quota (10k units/day) to drain within
// a single user session. The cron pre-warmer at
// /api/discover/refresh-videos writes here; the user-facing route
// /api/discover/videos reads here and falls back to stale rows when
// the upstream API returns quotaExceeded.
model DiscoverVideoCache {
  key       String   @id // e.g. "videos:claude:week"
  payload   Json
  fetchedAt DateTime
  expiresAt DateTime

  @@index([expiresAt])
}
